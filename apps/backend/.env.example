# Server
PORT=3001

# Supabase (service role — full DB access, never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter (for embeddings via text-embedding-3-small + future LLM calls)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Shared webhook secret — verified on all /webhook/* and admin endpoints
# Set the same value in ElevenLabs webhook config and tablet env
WEBHOOK_SECRET=your-shared-secret-here
