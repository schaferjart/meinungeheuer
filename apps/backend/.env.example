# Server
PORT=3001

# Supabase (service role — full DB access, never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (for text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-key-here

# Shared webhook secret — verified on all /webhook/* and admin endpoints
# Set the same value in ElevenLabs webhook config and tablet env
WEBHOOK_SECRET=your-shared-secret-here
